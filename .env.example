# =============================================================
# PedalNation — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
#
# Supabase project: ehlsnvfzhrtyscsgimdm
# Dashboard: https://app.supabase.com/project/ehlsnvfzhrtyscsgimdm
