# -----------------------------------------------------------
# Supabase — PUBLIC (safe to expose to the browser)
# -----------------------------------------------------------
# The URL of your Supabase project (found in Settings > API)
PUBLIC_SUPABASE_URL=https://ehlsnvfzhrtyscsgimdm.supabase.co

# The anon/public key for client-side access (found in Settings > API)
PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------
# Supabase — SECRET (server-side only, never expose to browser)
# -----------------------------------------------------------
# The service role key for privileged server-side operations
# (found in Settings > API — keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------
# Optional / Future use
# -----------------------------------------------------------
# The public base URL of your deployment (used for OG images, sitemaps, etc.)
# Defaults to https://pedalnation.com in production
# PUBLIC_BASE_URL=https://pedalnation.com
